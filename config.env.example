# RUHI shared configuration — copy to config.env and fill in.
# config.env is gitignored. Never commit real keys.

# === App mode ===
# "chat" → RUHI Chat (multilingual Indian-language web chatbot)
# "jarvis" → RUHI Jarvis (local agentic dashboard, offline voice)
RUHI_APP_MODE=chat

# === Languages (RUHI Chat) ===
# ISO 639-1 codes, comma-separated. Default = the 10 target Indian languages.
RUHI_SUPPORTED_LANGUAGES=te,hi,ta,kn,ml,bn,mr,gu,pa,or
RUHI_DEFAULT_LANGUAGE=auto

# === Hosts ===
RUHI_CHAT_HOST=0.0.0.0
RUHI_CHAT_PORT=8001
RUHI_JARVIS_HOST=127.0.0.1
RUHI_JARVIS_PORT=8002

# === LLM providers ===
# Chat default: gemini | openai
# Jarvis default: ollama
RUHI_CHAT_LLM_PROVIDER=gemini
RUHI_JARVIS_LLM_PROVIDER=ollama

OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# === Sarvam (RUHI Chat — PRIMARY speech & translation) ===
# Treat 1000 credits as dev budget; cache is mandatory (see shared/cache/sarvam.py).
SARVAM_API_KEY=
SARVAM_CACHE_PATH=.cache/sarvam.sqlite

# === Bhashini (RUHI Chat — fallback, when key is acquired) ===
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=

# === Voice (RUHI Jarvis — fully offline) ===
JARVIS_STT_PROVIDER=whisper          # whisper
JARVIS_TTS_PROVIDER=piper            # piper | vibevoice (requires GPU)
WHISPER_MODEL=base.en
PIPER_VOICE=en_US-lessac-medium

# === Memory ===
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=.cache/chroma

# === Tools (ported from old codebase) ===
OPENWEATHER_API_KEY=
WOLFRAM_APP_ID=
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.pickle
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
NEWS_API_KEY=
CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_CALENDAR_ID=primary

# === Legacy voice (optional, kept for tts.py providers — not used by default) ===
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
ELEVENLABS_KEY=

# === Tracing / dev ===
RUHI_ENABLE_TOOL_TRACE=true
RUHI_ENABLE_LIVE_LOGS=true
